# Port to listen on
PORT=3000

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Header set by the forward-auth proxy containing the username
USER_HEADER=Remote-User

# Group-based access control (oauth2-proxy forward-auth convention).
# USER_GROUP_HEADER carries a comma-separated group list; leave
# AUTHORIZED_GROUPS empty to allow any authenticated user.
USER_GROUP_HEADER=X-Forwarded-Groups
AUTHORIZED_GROUPS=

# IPs/CIDRs whose auth headers are trusted (the forward-auth proxies).
# Empty = accept from anywhere. Example: 10.0.0.5, 192.168.0.0/16
ALLOWED_PROXIES=

# Create-a-Container manager
MANAGER_URL=https://manager.os.mieweb.org
MANAGER_API_KEY=changeme
SITE_ID=1

# Container settings
TEMPLATE=ozwell-studio
HOSTNAME_PREFIX=ozwell-studio

# External domain the container's HTTP services are published under:
#   https://{hash}.{EXTERNAL_DOMAIN}         -> APP_PORT
#   https://{hash}-studio.{EXTERNAL_DOMAIN}  -> STUDIO_PORT (users are redirected here)
EXTERNAL_DOMAIN=os.mieweb.org
APP_PORT=3000
STUDIO_PORT=6080

# Path users land on within the studio service
STUDIO_PATH=/studio/

# Job polling
POLL_INTERVAL_MS=3000
PROVISION_TIMEOUT_MS=600000
